---
const pasos = [
  {
    numero: '01',
    titulo: 'Consulta Inicial',
    descripcion: 'Analizamos tu caso y la notificación que recibiste sin costo'
  },
  {
    numero: '02',
    titulo: 'Evaluación',
    descripcion: 'Determinamos el valor real de la indemnización que corresponde'
  },
  {
    numero: '03',
    titulo: 'Negociación',
    descripcion: 'Representamos tus intereses frente a la empresa constructora'
  },
  {
    numero: '04',
    titulo: 'Acuerdo',
    descripcion: 'Conseguimos una indemnización justa y te acompañamos hasta el cierre'
  }
];
---

<section id="proceso" class="py-20 bg-white scroll-mt-20">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Nuestro Proceso
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Te acompañamos en cada paso para asegurar que recibas una indemnización justa
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {pasos.map((paso, index) => (
        <div class="relative">
          {index < pasos.length - 1 && (
            <div class="hidden lg:block absolute top-12 left-full w-full h-0.5 bg-gray-200 -translate-x-1/2 z-0">
              <svg class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1 w-3 h-3 text-gray-400" fill="currentColor" viewBox="0 0 12 12">
                <path d="M0 6l12-6v12z" />
              </svg>
            </div>
          )}
          
          <div class="relative z-10">
            <div class="text-6xl font-bold text-gray-200 mb-2">{paso.numero}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{paso.titulo}</h3>
            <p class="text-gray-600 leading-relaxed">{paso.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
