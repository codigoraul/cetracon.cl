---
import { getServicios, getContactoInfo } from '../lib/wordpress';

const servicios = await getServicios();
const contacto = await getContactoInfo();
---

<footer class="bg-dark text-white">
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <img src="/images/logo-cetracon.svg" alt="CTRA Logo" class="h-12 w-auto mb-4 brightness-0 invert" />
        <p class="text-gray-300 text-sm leading-relaxed">
          Especialistas en negociación territorial con 13 años de experiencia. Defendemos los derechos de propietarios afectados por obras de infraestructura.
        </p>
      </div>
      
      <div>
        <h3 class="text-lg font-semibold mb-4">Nuestros Servicios</h3>
        <ul class="space-y-2">
          {servicios.map((servicio) => (
            <li>
              <a href={`/servicios/${servicio.slug}`} class="text-gray-300 hover:text-secondary transition-colors text-sm">
                {servicio.title.rendered}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h3 class="text-lg font-semibold mb-4">Información de Contacto</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-gray-300">{contacto.telefono}</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="text-gray-300">{contacto.email}</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-300">{contacto.direccion}</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-300">{contacto.horario}</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-700 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center text-sm text-gray-400">
      <p>© 2025 Cetraconsultores por <a href="https://diseñopaginas.cl" target="_blank">diseñopaginas</a></p>
     
    </div>
  </div>
</footer>
