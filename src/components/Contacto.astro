---
import { getContactoInfo, getServicios } from '../lib/wordpress';

const contacto = await getContactoInfo();
const servicios = await getServicios();
---

<section id="contacto" class="relative py-20 bg-cover bg-center bg-no-repeat scroll-mt-20" style="background-image: url('/images/fondo-contacto.webp');">
  <div class="absolute inset-0 bg-white/60"></div>
  <div class="container-custom relative z-10">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Contáctanos
      </h2>
      <p class="text-lg text-gray-600">
        Estamos listos para ayudarte a defender tus derechos
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      <div>
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Información de Contacto</h3>
          
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="ml-4">
                <div class="text-sm text-gray-500 font-medium">Teléfono</div>
                <div class="text-gray-900 font-semibold">{contacto.telefono}</div>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="ml-4">
                <div class="text-sm text-gray-500 font-medium">Email</div>
                <div class="text-gray-900 font-semibold">{contacto.email}</div>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div class="ml-4">
                <div class="text-sm text-gray-500 font-medium">Dirección</div>
                <div class="text-gray-900 font-semibold">{contacto.direccion}</div>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="ml-4">
                <div class="text-sm text-gray-500 font-medium">Horario</div>
                <div class="text-gray-900 font-semibold">{contacto.horario}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <div>
        <form class="bg-white rounded-xl p-8 shadow-lg">
          <div class="space-y-4">
            <div>
              <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Nombre</label>
              <input type="text" id="nombre" name="nombre" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" />
            </div>
            
            <div>
              <label for="telefono" class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" />
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" />
            </div>
            
            <div>
              <label for="tipo-consulta" class="block text-sm font-medium text-gray-700 mb-2">Tipo de consulta</label>
              <select id="tipo-consulta" name="tipo-consulta" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition">
                <option value="">Selecciona un tipo de obra</option>
                {servicios.map((servicio) => (
                  <option value={servicio.slug}>{servicio.title.rendered}</option>
                ))}
              </select>
            </div>
            
            <div>
              <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-2">Mensaje</label>
              <textarea id="mensaje" name="mensaje" rows="4" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition resize-none"></textarea>
            </div>
            
            <button type="submit" class="w-full btn-primary text-lg">
              Enviar Consulta
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
